# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL (used by Django and the db service)
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Heroku sets DATABASE_URL automatically when Postgres is attached.
# On Heroku, also set ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS (see README).
